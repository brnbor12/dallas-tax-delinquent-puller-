# Database
POSTGRES_USER=seller
POSTGRES_PASSWORD=seller_pass
POSTGRES_DB=motivated_seller
DATABASE_URL=postgresql+asyncpg://seller:seller_pass@db:5432/motivated_seller

# Redis
REDIS_URL=redis://redis:6379/0

# Auth (Clerk)
CLERK_SECRET_KEY=sk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...

# Geocoding
GOOGLE_MAPS_API_KEY=
# Set GEOCODER=nominatim to use free Nominatim instead of Google
GEOCODER=nominatim

# ATTOM Data (licensed MLS/property data)
ATTOM_API_KEY=

# Proxy (Phase 3 - leave empty for dev)
PROXY_HOST=
PROXY_PORT=
PROXY_USER=
PROXY_PASS=

# App
SECRET_KEY=change-me-in-production
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:5173
